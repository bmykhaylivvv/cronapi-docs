            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Crons",
            "pages": [
              "api-reference/crons/list",
              "api-reference/crons/create",
              "api-reference/crons/get",
              "api-reference/crons/update",
              "api-reference/crons/delete",
              "api-reference/crons/trigger",
              "api-reference/crons/runs"
            ]
          },
          {
            "group": "Jobs",
            "pages": [
              "api-reference/jobs/list",
              "api-reference/jobs/create",
              "api-reference/jobs/get",
              "api-reference/jobs/update",
              "api-reference/jobs/delete",
              "api-reference/jobs/trigger",
              "api-reference/jobs/runs"
            ]
          }
        ]
      }
